# ─── Awaqi Environment Variables ───────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# ─── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# Used by Docker Compose to create the database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=awaqi_db

# Used by the Python backend (must match the Docker Compose values above)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/awaqi_db
# Used by the Next.js frontend (Better Auth needs a sync driver)
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/awaqi_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
# Required for document ingestion (text extraction + embeddings)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# ─── Authentication (Better Auth) ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-in-production

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── API (FastAPI) ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
SESSION_TOKEN_SECRET=dev-session-token-secret-change-me
MAX_UPLOAD_BYTES=10485760

# ─── Rate Limiting ───────────────────────────────────────────────────────────
TRUST_X_FORWARDED_FOR=false
TRUSTED_PROXIES=

# ─── Debug ───────────────────────────────────────────────────────────────────
DB_ECHO=false
